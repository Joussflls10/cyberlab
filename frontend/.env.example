# Copy to frontend/.env and adjust if your backend runs elsewhere.
# Preferred (dev): let the frontend call /api and configure Vite proxy target:
VITE_BACKEND_URL=http://127.0.0.1:18080
VITE_DEV_PORT=5173
VITE_DEV_HOST=0.0.0.0

# Optional (advanced): bypass proxy and call a direct API origin.
# VITE_API_URL=http://127.0.0.1:18080
